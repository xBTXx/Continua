{
  "chat_models": [
    {
      "id": "deepseek/deepseek-v3.2",
      "name": "DeepSeek V3.2",
      "capabilities": ["reasoning"]
    },
    {
      "id": "openai/gpt-5.2",
      "name": "GPT-5.2",
      "capabilities": ["reasoning", "effort", "vision"]
    },
    {
      "id": "openai/gpt-5-mini",
      "name": "GPT-5 Mini",
      "capabilities": ["reasoning", "effort", "vision"]
    },
    {
      "id": "google/gemini-3-flash-preview",
      "name": "Gemini 3 Flash",
      "capabilities": ["reasoning", "effort", "vision"]
    },
    {
      "id": "google/gemini-3-pro-preview",
      "name": "Gemini 3 Pro",
      "capabilities": ["vision"]
    }
  ],
  "memory_agent": {
    "default_model": "deepseek/deepseek-v3.2",
    "parameters": {
      "reasoning": false,
      "temperature": 0.1
    },
    "trigger_interval": 5,
    "history_window": 20,
    "candidate_count": 15
  },
  "embeddings": {
    "provider": "openrouter",
    "model": "google/gemini-embedding-001"
  },
  "retrieval": {
    "top_k": 8
  },
  "vector_db": {
    "provider": "chroma",
    "url": "http://vector:8000"
  },
  "sql_db": {
    "provider": "postgres",
    "url": "postgres://app:change-me@db:5432/app"
  }
}
