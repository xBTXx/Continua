# Public-safe starter template for local Docker startup.
# Copy this file to `.env` before running `docker compose build`.
# Real secrets and operator-specific endpoints have been replaced with placeholders.

# Core application and providers
# Required: replace with a real OpenRouter key or chat/embedding features will fail.
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
NEXT_PUBLIC_BASE_PATH=

# Docker database defaults. If you change these, keep DATABASE_URL in sync.
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=app

# Storage and memory collections
DATABASE_URL=postgres://app:change-me@db:5432/app
CHROMA_URL=http://vector:8000
CHROMA_COLLECTION=assistant_memories
CHROMA_PERSONAL_COLLECTION=assistant_personal_memories
CHROMA_TENANT=default
CHROMA_DATABASE=default
CHROMA_RESET_ON_DIM_MISMATCH=true
PERSONAL_MEMORY_TOOLS_ENABLED=true

# Authentication and operator admin
AUTH_BOOTSTRAP_USERNAME=admin
# Required: change before exposing the app beyond your own machine.
AUTH_BOOTSTRAP_PASSWORD=change-this-before-first-login
# Required: use a long random secret, at least 24 characters.
AUTH_SESSION_SECRET=replace-with-a-random-48-char-secret
AUTH_SESSION_TTL_HOURS=168
USER_ADMIN_TOOLS_ENABLED=true

# SSEF (Skill Evolution Framework)
SSEF_ENABLED=true
# Relative to ASSISTANT_WORKSPACE_ROOT.
SSEF_ROOT_DIR=.ssef
SSEF_FORGE_MAX_ATTEMPTS=3
SSEF_FORGE_MODELS=openai/gpt-5.3-codex,anthropic/claude-sonnet-4.6,z-ai/glm-5,google/gemini-3-flash-preview
SSEF_FORGE_DEFAULT_MODEL=openai/gpt-5.3-codex
SSEF_FORGE_DEFAULT_REASONING_EFFORT=high
SSEF_SANDBOX_TIMEOUT_MS=20000
SSEF_SANDBOX_MAX_OUTPUT_CHARS=24000
SSEF_SANDBOX_MAX_MEMORY_MB=512
SSEF_SANDBOX_MAX_CPU_SECONDS=60
SSEF_SANDBOX_MAX_PROCESS_SPAWNS=3
SSEF_DEPENDENCY_INSTALL_TIMEOUT_MS=180000
SSEF_RUNTIME_AUTO_INSTALL_DEPENDENCIES=true
SSEF_RUNTIME_CHAT_MAX_TOOLS=8
SSEF_RUNTIME_IDLE_MAX_TOOLS=6
SSEF_RUNTIME_SELECTION_MIN_SCORE=0.14
SSEF_RUNTIME_SELECTION_MAX_QUERY_TOKENS=24
SSEF_PROPOSAL_TOOL_ENABLED=true
# Keep false unless you explicitly want autonomous idle spark submissions.
SSEF_PROPOSAL_TOOL_IDLE_ENABLED=false
SSEF_SKILL_EMBEDDINGS_COLLECTION=ssef_skills_index
SSEF_SKILL_EMBEDDINGS_MODEL=google/gemini-embedding-001

# Retrieval, reranking, and rolling memory
CONVERSATION_EXCERPT_MEMORY_LIMIT=6
CONVERSATION_EXCERPT_MESSAGE_LIMIT=9
CONVERSATION_EXCERPT_MESSAGE_MAX_CHARS=300
HYBRID_SEARCH_ENABLED=true
HYBRID_RRF_K=60
HYBRID_SEMANTIC_WEIGHT=60
RERANK_ENABLED=true
RERANK_MODEL=google/gemini-2.5-flash-lite
RERANK_TOP_N=8
RERANK_CANDIDATE_MULTIPLIER=2
DYNAMIC_TOPK_ENABLED=true
TOPK_BASE=6
TOPK_SPECIFIC_REDUCTION=2
TOPK_EXPLORATORY_BOOST=4
NEGATIVE_FILTERING_ENABLED=true
STALENESS_DECAY_ENABLED=true
STALENESS_DECAY_HALF_LIFE_DAYS=30
CROSS_COLLECTION_EXPANSION_ENABLED=true
CROSS_COLLECTION_MAX_TOPICS=2
ROLLING_MEMORY_MAX_TOTAL=25
ROLLING_MEMORY_MAX_MAIN=10
ROLLING_MEMORY_MAX_PERSONAL=10
ROLLING_MEMORY_ADD_MAIN=4
ROLLING_MEMORY_ADD_PERSONAL=4
ROLLING_MEMORY_TTL_DAYS=14
IDLE_WORKSPACE_MEMORY_MAX_TOTAL=20
IDLE_WORKSPACE_MEMORY_MAX_MAIN=12
IDLE_WORKSPACE_MEMORY_MAX_PERSONAL=8
IDLE_WORKSPACE_MEMORY_ADD_MAIN=3
IDLE_WORKSPACE_MEMORY_ADD_PERSONAL=3

# IDLE cognition
IDLE_ENABLED=true
IDLE_INTERVAL_MS=15000
IDLE_COOLDOWN_MS=1500000
IDLE_BURST_COUNT=4
IDLE_MODEL_LITE=google/gemini-2.5-flash-lite
IDLE_MODEL_SMART=google/gemini-3-flash-preview
IDLE_REASONING_LEVEL=high
IDLE_WORKSPACE_MAX_STEPS=30
IDLE_TOP_K=8
IDLE_THOUGHT_TTL_DAYS=1
IDLE_PERSONA_MODE=static
IDLE_PERSONA_SOURCE=system_prompt
IDLE_PERSONA_TEXT=
IDLE_PERSONA_PROFILE=
IDLE_SALIENCE_STORE_THRESHOLD=0.26
IDLE_SALIENCE_ESCALATE_THRESHOLD=0.78
IDLE_SALIENCE_COOLDOWN_MS=19800000
IDLE_SPARK_INTERVAL_MIN_MS=120000
IDLE_SPARK_INTERVAL_MAX_MS=190000
IDLE_SEED_COOLDOWN_MS=1800000
IDLE_ENERGY_HALF_LIFE_MS=7200000
IDLE_PERSONA_SEMANTIC_THRESHOLD=0.78
IDLE_PERSONA_KEYWORD_BOOST=0.25
IDLE_PERSONA_SEMANTIC_BOOST=0.15
IDLE_NOVELTY_LOW_BOOST=0.05
IDLE_NOVELTY_MEDIUM_BOOST=0.09
IDLE_NOVELTY_HIGH_BOOST=0.1
IDLE_SEED_WEIGHT_RECENCY_HALF_LIFE_MS=86400000
IDLE_SEED_WEIGHT_RECENCY_FACTOR=0.5
IDLE_SEED_WEIGHT_INTENSITY_FACTOR=0.3
IDLE_SEED_WEIGHT_FREQUENCY_FACTOR=0.2
IDLE_CHAIN_ENABLED=true
IDLE_CHAIN_MAX_DEPTH=2
IDLE_CHAIN_PROBABILITY=0.3
IDLE_MOMENTUM_ENABLED=true
IDLE_MOMENTUM_DECAY_RATE=0.1
IDLE_MOMENTUM_IMPACT=0.15
IDLE_CREATIVITY_SAVE_RATE=0.15

# Tool loop and context budgets
CHAT_MAX_TOOL_ROUNDS=30
CHAT_TOOL_CONTEXT_MAX_CHARS=12000
CHAT_TOOL_ROUND_CONTEXT_MAX_CHARS=24000
IDLE_TOOL_CONTEXT_MAX_CHARS=8000
IDLE_TOOL_ROUND_CONTEXT_MAX_CHARS=20000
IDLE_WORKSPACE_TOOL_CONTEXT_MAX_CHARS=8000

# Email and Outlook OAuth (optional unless you want Outlook/email features)
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret
OUTLOOK_TENANT_ID=consumers
OUTLOOK_REDIRECT_URI=http://localhost:3000/api/oauth/outlook/callback
OUTLOOK_SCOPES=offline_access Mail.Read Mail.ReadWrite Mail.Send User.Read
OUTLOOK_STATE_SECRET=replace-with-a-random-state-secret
MCP_EMAIL_ENABLED=false
MCP_EMAIL_CONFIG_PATH=

# Web, maps, and research tools
WIKI_USER_AGENT=Assistant/1.0 (you@domain.com)
# Optional: only needed for maps tools.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
MAPS_TOOLS_ENABLED=true
ARXIV_TOOLS_ENABLED=true
ARXIV_API_BASE=https://export.arxiv.org
ARXIV_BASE_URL=https://arxiv.org
ARXIV_USER_AGENT=Assistant/1.0 (you@domain.com)
ARXIV_WORKSPACE_DIR=arxiv
ARXIV_PYTHON_BIN=/opt/arxiv-venv/bin/python

# Workspace, docs, scratchpad, and Crawl4AI
# The host path is bind-mounted into the app container for local file tools.
ASSISTANT_WORKSPACE_HOST_PATH=./workspace
DOC_ALLOWED_EXTENSIONS=*
DOC_SEARCH_EXTENSIONS=*
SCRATCHPAD_TOOLS_ENABLED=true
SCRATCHPAD_ASSISTANT_WINDOW=2
SCRATCHPAD_NOTE_LIMIT=12
CRAWL4AI_TOOLS_ENABLED=true
CRAWL4AI_BASE_URL=http://crawl4ai:11235
CRAWL4AI_API_KEY=
CRAWL4AI_MCP_COMMAND=npx
CRAWL4AI_MCP_ARGS=-y mcp-crawl4ai-ts
CRAWL4AI_MCP_URL=
CRAWL4AI_FORCE_LEAN_OUTPUT=true
CRAWL4AI_MAX_TEXT_CHARS=24000
CRAWL4AI_MAX_CONTENT_ITEMS=12
CRAWL4AI_MAX_RECURSION_DEPTH=6
